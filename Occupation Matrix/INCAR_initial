SYSTEM = Ceria_limpia 

Start parameter for this run:
ISTART  = 1         ! start job from scratch (see INIWAV)
INIWAV  = 1         ! Fill wavefunctions arrays with random numbers
ICHARGE = 1         ! Calculate charge density from initial wave function

Electronic relaxation:
ENCUT   = 415.0     ! Cutoff energy for plane waves basis set in eV  
##IALGO   = 38        ! IALGO = 38 + 48; IALGO = 48 does not work for Ce-oxides
ALGO = ALL
LSUBROT = .FALSE.
NELMIN  = 8         ! Minimum number of eletronic selfconsistency (SC) steps
NELM    = 2000       ! Maximum number of electronic SC steps
NELMDL  = -15       ! Number of NON-SCF steps (SHOULD be NEGATIVE)
EDIFF   = 1E-6      ! Global-break condition for the electronic SC-loop (ELM)
##NBANDS  = 288
IMIX    = 1
AMIX    = 0.10
BMIX    = 0.0001
AMIX_MAG    = 0.40
BMIX_MAG    = 0.0001

Calculation mode:
PREC    = Accurate  ! Calculation level (Changes FFT-grids)
ISPIN   = 2         ! spin-polarized calculations
##MAGMOM  = 8*1 8*0 28*0 1*0 1*0 4*0
NUPDOWN = 5.0185
LMAXMIX = 6         ! PAW flag
ADDGRID = .TRUE.    ! PAW flag
LASPH   = .TRUE.    ! PAW flag
ISYM    = 0

#PBE+U calculation:
LDAU      = .TRUE.
LDAUTYPE  = 2
LDAUL     = 3     -1    -1        
LDAUU     = 4.50  0.00  0.00    
LDAUJ     = 0.00  0.00  0.00    
LDAUPRINT = 2

##OCCEXT = 1

Integration over the Brillouin zone (BZ):
ISMEAR  = 0         ! Gaussian smearing
SIGMA   = 0.05      

Ionic relaxation:
NSW     = 1000       ! Number of ionic steps
EDIFFG  = -0.01     ! stop if all forces are smaller than |EDIFFG|
IBRION  = 2         
ISIF    = 0         ! Calculate FORCE and Relax Ions 
POTIM   = 0.015


Van der Waals Correction
vdW-D3
 
IVDW=11

DOS calculation:
LORBIT  = 11        ! Calculate the DOS without providing the Wigner Seitz radius
NEDOS   = 1001      ! Number of points to calculate the DOS

VASP OUTPUTs
NWRITE  = 2         ! Determines how much information will be written in OUTCAR
LCHARG = .TRUE.
LWAVE = .FALSE.

Key for parallel mode calculation:
NPAR = 16   ! Con 64 proc NPAR = 8 con 32 NPAR = 4  
##KPAR = 5
EOF
